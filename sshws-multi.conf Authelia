# ========================================================
# Bloco NGINX para autenticação extra com Authelia e portal personalizado.
# CONFIGURAÇÃO DE MAPS (Essencial para WebSockets do CasaOS)
# ========================================================
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# ========================================================
# 1. PORTAL (portal.maritimavpn.online)
# ========================================================
server {
    listen 80;
    server_name portal.maritimavpn.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name portal.maritimavpn.online;

    ssl_certificate /etc/letsencrypt/live/maritimavpn.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/maritimavpn.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # O Portal é público (Bypass do Authelia)
    location / {
        root /var/www/pirata;
        index index.html index.htm;
        try_files $uri $uri/ =404;
    }
}

# ========================================================
# 2. AUTHELIA (auth.maritimavpn.online)
# ========================================================
server {
    listen 80;
    server_name auth.maritimavpn.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name auth.maritimavpn.online;

    ssl_certificate /etc/letsencrypt/live/maritimavpn.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/maritimavpn.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location / {
        proxy_pass http://127.0.0.1:9091;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;
    }
}

# ========================================================
# 3. CASAOS (casa.maritimavpn.online)
# ========================================================
server {
    listen 80;
    server_name casa.maritimavpn.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name casa.maritimavpn.online;

    ssl_certificate /etc/letsencrypt/live/maritimavpn.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/maritimavpn.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Desativa buffers para evitar engasgos nas APIs do CasaOS e uploads
    proxy_buffering off;
    proxy_request_buffering off;

    # Redireciona usuários não autenticados de volta para o Portal via Authelia
    error_page 401 =302 https://auth.maritimavpn.online/?rd=https://portal.maritimavpn.online;

    # Endpoint interno de validação do Authelia (Subrequest)
    location = /authelia {
        internal;
        proxy_pass http://127.0.0.1:9091/api/authz/auth-request;

        proxy_set_header X-Original-URL $scheme://$host$request_uri;
        proxy_set_header X-Original-Method $request_method;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Uri $request_uri;
        proxy_set_header Content-Length "";
        proxy_pass_request_body off;
    }

    # 🔥 EXCEÇÃO DE CORS/API (Ignora o Authelia para que as APIs locais funcionem)
    location ~* ^/(v1|v2|api|site.webmanifest|api/health) {
        proxy_pass http://127.0.0.1:81;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;
        
        # Suporte a WebSockets para a App Store e Status do CasaOS
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # INTERFACE DO CASAOS PROTEGIDA (Bloqueado pelo Authelia)
    location / {
        auth_request /authelia;

        # Repassa os dados do usuário logado no Authelia para o CasaOS
        auth_request_set $user $upstream_http_x_remote_user;
        auth_request_set $email $upstream_http_x_remote_email;
        proxy_set_header X-Forwarded-User $user;
        proxy_set_header X-Forwarded-Email $email;

        proxy_pass http://127.0.0.1:81;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;

        # Suporte a WebSockets na raiz da interface
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
