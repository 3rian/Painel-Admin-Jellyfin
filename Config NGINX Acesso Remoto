# NOVO BLOCO PARA O JELLYFIN
server {
    listen 80;
    server_name desacato.maritimavpn.shop;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name desacato.maritimavpn.shop;

    # --- Configuração do Certificado SSL ---
    ssl_certificate /etc/letsencrypt/live/maritimavpn.shop/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/maritimavpn.shop/privkey.pem;

    # --- Configurações de Segurança e Performance (Recomendado) ---
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    proxy_buffering off; # Essencial para streaming, evita travamentos[reference:1]

    # --- Bloco de Proxy Principal ---
    location / {
        proxy_pass http://127.0.0.1:8097;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;
    }

    # --- Bloco Essencial para WebSocket (SyncPlay, notificações, etc.) ---
    location /socket {
        proxy_pass http://127.0.0.1:8097;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $http_host;
    }
}
